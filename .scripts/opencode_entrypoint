#!/bin/bash

# This should be auto started by the default CMD.
# If overridden, it's suggested to execute this prior to any custom
# editing to avoid missing services/tools.

MAX_TRIES=10

trap 'echo "Shutting down..."; kill $(jobs -p); wait; exit 0' TERM INT

speakturbo-daemon &

attempt=1

: "${START_MSG:="TTS Started!"}"

until speakturbo ". ${START_MSG}" > /dev/null 2>&1; do
    if [ $attempt -ge $MAX_TRIES ]; then
        echo "Error: TTS failed to start after $MAX_TRIES attempts (${attempt}×5s = $((attempt*5)) seconds). Giving up."
        exit 1
    fi

    echo "TTS still loading... (attempt $attempt/$MAX_TRIES)"
    sleep 5
    ((attempt++))
done

echo "${START_MSG}"

# Persist a running container indefinitely!
sleep infinity
